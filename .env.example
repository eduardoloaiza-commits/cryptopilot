# Modo de operación: PAPER | TESTNET | LIVE
MODE=PAPER

# OpenAI (los agentes corren sobre Chat Completions)
OPENAI_API_KEY=sk-...

# Binance (Testnet spot: https://testnet.binance.vision/)
# LIVE: https://api.binance.com
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET=

# Postgres (Neon via Vercel Marketplace)
# Estas variables las setea automaticamente la integracion Neon en Vercel.
# Localmente, corre: vercel env pull .env.local
POSTGRES_PRISMA_URL=postgresql://user:pass@host-pooler/db?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/db?sslmode=require

# Clerk (auth para el dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Worker
CYCLE_INTERVAL_MS=30000
DAILY_REPORT_CRON=59 23 * * *
DAILY_REPORT_TZ=America/Santiago
INITIAL_CAPITAL_USDT=1000

# Modelos por agente (override opcional). Defaults son mixtos:
# - Analyst en gpt-4.1-mini (decisiones, mejor calidad/precio)
# - Risk pre-cycle/pre-execution en gpt-4.1-nano (casi determinista)
# - Risk sl-tp-sweep en gpt-4.1-mini (respaldo informativo)
# - Trader + Execute + Accountant en gpt-4.1-nano (ejecución barata)
# MODEL_ANALYST=gpt-4.1-mini
# MODEL_RISK_PRECYCLE=gpt-4.1-nano
# MODEL_RISK_EXEC=gpt-4.1-nano
# MODEL_RISK=gpt-4.1-mini
# MODEL_TRADER=gpt-4.1-nano
# MODEL_EXECUTE=gpt-4.1-nano
# MODEL_ACCOUNTANT=gpt-4.1-nano
