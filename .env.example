# Modo de operación: PAPER | TESTNET | LIVE
MODE=PAPER

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Binance (Testnet spot: https://testnet.binance.vision/)
# LIVE: https://api.binance.com
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET=

# Postgres (Neon via Vercel Marketplace)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# Clerk (auth para el dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Worker
CYCLE_INTERVAL_MS=30000
DAILY_REPORT_CRON=59 23 * * *
DAILY_REPORT_TZ=America/Santiago
